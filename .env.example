# --- SUPABASE CONFIG ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Server-only: for generateLink (number-match magic link). Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- AUTH CONFIG (FOR ACCOUNTS) ---
# En production: .streettaco.com.au | En dev: leave empty
NEXT_PUBLIC_COOKIE_DOMAIN=

# --- GOOGLE OAUTH ---
# Get these from Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- REDIRECTION ---
NEXT_PUBLIC_ACCOUNTS_ORIGIN=https://accounts.streettaco.com.au
NEXT_PUBLIC_PLUS_ORIGIN=https://plus.streettaco.com.au

# --- NUMBER-MATCH EMAIL (Resend) ---
# We send the magic-link email ourselves with the match number and link to callback.
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=StreetTaco <noreply@yourdomain.com>